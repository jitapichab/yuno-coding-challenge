      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{app=\"transaction-engine\", namespace=\"$namespace\"}[1m]))",
          "legendFormat": "Total req/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Percentage of successful (2xx) responses over the last 5 minutes",
      "fieldConfig": {
        "defaults": {
